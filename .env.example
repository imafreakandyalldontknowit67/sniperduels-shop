# Sniper Duels Shop environment template
# Copy to .env.local for local development or enter these names in Coolify.
# Never commit real secret values.

# Runtime/build flags
NODE_ENV=development
ANALYZE=false

# Public/base URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Roblox OAuth
ROBLOX_CLIENT_ID=your_roblox_client_id_here
ROBLOX_CLIENT_SECRET=your_roblox_client_secret_here

# Discord OAuth / guild linking
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# Session / admin
SESSION_SECRET=generate_a_random_32_plus_character_secret_here
ADMIN_USER_IDS=123456789,987654321

# PostgreSQL / Prisma
DATABASE_URL="postgresql://sniper_app:your_password@localhost:5432/sniper_duels"

# Payment provider: PandaBase card checkout
PANDABASE_DEV_MODE=true
PANDABASE_SECRET_KEY=sk_your_pandabase_secret_key_here
PANDABASE_SHOP_ID=shp_your_pandabase_shop_id_here
PANDABASE_WEBHOOK_SECRET=whsec_your_pandabase_webhook_secret_here
PANDABASE_API_KEY=your_pandabase_api_key_here
PANDABASE_API_STORE_ID=your_pandabase_store_id_here

# Payment provider: NowPayments crypto checkout
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_here

# Payment provider: NearPayments crypto checkout
NEARPAYMENTS_API_KEY=your_nearpayments_api_key_here
NEARPAYMENTS_IPN_SECRET=your_nearpayments_ipn_secret_here

# Roblox private server links shown only when the order reaches the front of queue
PRIVATE_SERVER_URL=https://www.roblox.com/share?code=YOUR_DESKTOP_CODE_HERE&type=Server
PRIVATE_SERVER_URL_MOBILE=roblox://placeId=YOUR_PLACE_ID&gameInstanceId=YOUR_PRIVATE_SERVER_ID

# Trade bot API auth
BOT_API_KEY=generate_a_random_bot_api_key_here

# Discord webhooks / alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ORDER_WEBHOOK_HERE
ADMIN_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ADMIN_WEBHOOK_HERE
DISCORD_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ALERTS_WEBHOOK_HERE
HONEYPOT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_HONEYPOT_WEBHOOK_HERE

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://ph.sniperduels.shop
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key_for_server_queries
POSTHOG_PROJECT_ID=your_posthog_project_id_here
