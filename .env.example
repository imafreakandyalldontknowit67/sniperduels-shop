# Roblox OAuth
ROBLOX_CLIENT_ID=your_client_id_here
ROBLOX_CLIENT_SECRET=your_client_secret_here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Discord OAuth (for account linking)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Session
SESSION_SECRET=generate_a_random_32_char_string_here

# Admin (comma-separated Roblox user IDs who can access admin panel)
ADMIN_USER_IDS=123456789

# Pandabase Dev Mode (true = mock payments for local testing, false = real Pandabase API)
PANDABASE_DEV_MODE=false

# Pandabase Payment Processing
PANDABASE_SECRET_KEY=sk_your_pandabase_secret_key_here
PANDABASE_SHOP_ID=shp_your_pandabase_shop_id_here

# Private Server URL (server-only — gated to #1 in queue via API)
PRIVATE_SERVER_URL=https://www.roblox.com/share?code=YOUR_CODE_HERE&type=Server

# Discord Webhook (order/deposit notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# Trade Bot API Key (generate a random secret)
BOT_API_KEY=generate_a_random_bot_api_key_here

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://sniper_app:your_password@localhost:5432/sniper_duels"
