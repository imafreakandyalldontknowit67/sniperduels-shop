{
  "openapi": "3.0.3",
  "info": {
    "title": "Sniper Duels Auto Shop API",
    "version": "1.0.0",
    "description": "API for the Sniper Duels Auto Shop — a Roblox item shop with automated delivery.\n\n## Authentication\n- **Session auth**: Cookie-based JWT (`session` cookie). Obtained via Roblox OAuth flow.\n- **Bot auth**: `x-bot-api-key` header for delivery bot endpoints.\n- **Admin**: Determined server-side by checking the authenticated user's Roblox ID against the `ADMIN_IDS` environment variable.\n\n## E2E Flows\n\n### Purchase Flow\n1. User authenticates via Roblox OAuth (`GET /api/auth/roblox` → callback at `GET /redirect`).\n2. User deposits funds (`POST /api/deposits/create` → pay via Stripe checkout → `POST /api/deposits/verify`).\n3. User purchases an item (`POST /api/orders/purchase`) or gems (`POST /api/orders/purchase-gems`).\n4. User marks themselves ready for trade (`POST /api/orders/{id}/ready`).\n5. Delivery bot picks up order (`GET /api/bot/orders`), marks processing (`POST /api/bot/orders/{id}/processing`), then completes or fails it.\n\n### Discord Linking\n1. Authenticated user initiates Discord OAuth (`GET /api/auth/discord`).\n2. Callback links Discord account (`GET /api/auth/discord/callback`).\n3. User can unlink later (`POST /api/auth/discord/unlink`).\n\n## Security\n- Rate limiting per IP (varies by endpoint group).\n- CSRF protection on mutations (origin header check).\n- Auth lockout after 15 failed attempts within 5 minutes.\n- Session cookie: `httpOnly`, JWT signed with `SESSION_SECRET`.",
    "contact": {
      "name": "Sniper Duels"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Relative (same-origin)"
    }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication and OAuth flows" },
    { "name": "Public", "description": "Public endpoints (no auth required)" },
    { "name": "Orders", "description": "User order management" },
    { "name": "Deposits", "description": "Wallet deposits and payment verification" },
    { "name": "Admin", "description": "Admin-only management endpoints" },
    { "name": "Bot", "description": "Delivery bot endpoints (API key auth)" }
  ],
  "paths": {
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "operationId": "getMe",
        "summary": "Get current user info",
        "description": "Returns the authenticated user's profile, wallet balance, loyalty tier, and admin status. Auth is optional — returns null user if unauthenticated.",
        "security": [{ "sessionCookie": [] }, {}],
        "responses": {
          "200": {
            "description": "Current user info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "nullable": true,
                      "$ref": "#/components/schemas/User"
                    },
                    "isAdmin": { "type": "boolean" },
                    "discordLinked": { "type": "boolean" },
                    "discordUsername": { "type": "string", "nullable": true },
                    "walletBalance": { "type": "number", "format": "double", "description": "USD balance" },
                    "loyaltyTier": { "type": "string", "nullable": true, "description": "Current loyalty tier name" },
                    "loyaltyDiscount": { "type": "number", "format": "double", "description": "Discount multiplier (e.g. 0.05 = 5%)" },
                    "lifetimeSpend": { "type": "number", "format": "double" },
                    "canUseDiscordDiscount": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/roblox": {
      "get": {
        "tags": ["Auth"],
        "operationId": "initiateRobloxOAuth",
        "summary": "Initiate Roblox OAuth",
        "description": "Redirects the user to Roblox's OAuth authorization page. On success, Roblox redirects back to `GET /redirect`.",
        "responses": {
          "302": {
            "description": "Redirect to Roblox OAuth authorization URL"
          }
        }
      }
    },
    "/redirect": {
      "get": {
        "tags": ["Auth"],
        "operationId": "robloxOAuthCallback",
        "summary": "Roblox OAuth callback",
        "description": "Handles the OAuth callback from Roblox. Exchanges the authorization code for user info, creates a JWT session cookie, and redirects to the site.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Authorization code from Roblox"
          },
          {
            "name": "state",
            "in": "query",
            "schema": { "type": "string" },
            "description": "CSRF state parameter"
          },
          {
            "name": "error",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Error code if OAuth failed"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to site after login"
          }
        }
      }
    },
    "/api/auth/discord": {
      "get": {
        "tags": ["Auth"],
        "operationId": "initiateDiscordOAuth",
        "summary": "Initiate Discord OAuth",
        "description": "Redirects the authenticated user to Discord's OAuth page to link their Discord account.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "302": {
            "description": "Redirect to Discord OAuth authorization URL"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/discord/callback": {
      "get": {
        "tags": ["Auth"],
        "operationId": "discordOAuthCallback",
        "summary": "Discord OAuth callback",
        "description": "Handles the OAuth callback from Discord and links the Discord account to the authenticated user.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Authorization code from Discord"
          },
          {
            "name": "state",
            "in": "query",
            "schema": { "type": "string" },
            "description": "CSRF state parameter"
          },
          {
            "name": "error",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Error code if OAuth failed"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect after linking Discord"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/discord/unlink": {
      "post": {
        "tags": ["Auth"],
        "operationId": "unlinkDiscord",
        "summary": "Unlink Discord account",
        "description": "Removes the linked Discord account from the authenticated user's profile.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "302": {
            "description": "Redirect after unlinking"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "operationId": "logout",
        "summary": "Log out",
        "description": "Clears the session cookie and logs the user out.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Logged out",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/stock": {
      "get": {
        "tags": ["Public"],
        "operationId": "getStock",
        "summary": "Get all active stock items",
        "description": "Returns all stock items that are currently active and available for purchase.",
        "responses": {
          "200": {
            "description": "List of active stock items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/StockItem" }
                }
              }
            }
          }
        }
      }
    },
    "/api/gems/stock": {
      "get": {
        "tags": ["Public"],
        "operationId": "getGemStock",
        "summary": "Get gem stock level",
        "description": "Returns the current gem balance available for sale. Despite being under a public-looking path, this is effectively admin-only.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Gem stock level",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GemBalance"
                }
              }
            }
          }
        }
      }
    },
    "/api/settings": {
      "get": {
        "tags": ["Public"],
        "operationId": "getSettings",
        "summary": "Get site settings",
        "description": "Returns public site configuration flags.",
        "responses": {
          "200": {
            "description": "Site settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Settings"
                }
              }
            }
          }
        }
      }
    },
    "/api/orders/purchase": {
      "post": {
        "tags": ["Orders"],
        "operationId": "purchaseItem",
        "summary": "Purchase an item",
        "description": "Purchases a stock item using the user's wallet balance. Deducts the price and creates an order.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["itemId", "quantity"],
                "properties": {
                  "itemId": { "type": "string", "description": "Stock item ID" },
                  "quantity": { "type": "integer", "minimum": 1, "maximum": 10 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Purchase successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" },
                    "newBalance": { "type": "number", "format": "double" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "402": {
            "description": "Insufficient balance",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/orders/purchase-gems": {
      "post": {
        "tags": ["Orders"],
        "operationId": "purchaseGems",
        "summary": "Purchase gems",
        "description": "Purchases gems using the user's wallet balance. Tiered pricing: 1-9k = $2.90/k, 10-74k = $2.80/k, 75k+ = $2.65/k.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amountInK"],
                "properties": {
                  "amountInK": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 500,
                    "description": "Amount of gems to buy in thousands (e.g. 10 = 10,000 gems)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gem purchase successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" },
                    "newBalance": { "type": "number", "format": "double" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "402": {
            "description": "Insufficient balance",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/orders/{id}/status": {
      "get": {
        "tags": ["Orders"],
        "operationId": "getOrderStatus",
        "summary": "Get order status",
        "description": "Returns the status and queue position for an order. Only the order owner can view their own orders.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "responses": {
          "200": {
            "description": "Order status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" },
                    "queuePosition": { "type": "integer", "nullable": true, "description": "Position in delivery queue (null if not queued)" },
                    "estimatedMinutes": { "type": "integer", "nullable": true, "description": "Estimated minutes until delivery" },
                    "totalInQueue": { "type": "integer", "description": "Total orders currently in queue" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/orders/{id}/ready": {
      "post": {
        "tags": ["Orders"],
        "operationId": "markOrderReady",
        "summary": "Mark order ready for trade",
        "description": "User confirms they are ready to receive the in-game trade for this order.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["confirm"],
                "properties": {
                  "confirm": { "type": "boolean", "enum": [true] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order marked ready",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/deposits": {
      "get": {
        "tags": ["Deposits"],
        "operationId": "getDeposits",
        "summary": "Get user's deposits",
        "description": "Returns all deposits for the authenticated user.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "List of deposits",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Deposit" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/deposits/create": {
      "post": {
        "tags": ["Deposits"],
        "operationId": "createDeposit",
        "summary": "Create a deposit",
        "description": "Creates a new deposit and returns a Stripe checkout URL for payment.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount", "billing"],
                "properties": {
                  "amount": {
                    "type": "number",
                    "format": "double",
                    "minimum": 1,
                    "maximum": 500,
                    "description": "Deposit amount in USD"
                  },
                  "billing": { "$ref": "#/components/schemas/BillingInfo" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deposit created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "depositId": { "type": "string" },
                    "checkoutUrl": { "type": "string", "format": "uri", "description": "Stripe checkout URL" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/deposits/verify": {
      "post": {
        "tags": ["Deposits"],
        "operationId": "verifyDeposit",
        "summary": "Verify deposit payment",
        "description": "Checks with Stripe whether the deposit has been paid and credits the user's wallet if so.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["depositId"],
                "properties": {
                  "depositId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "description": "Payment status" },
                    "walletBalance": { "type": "number", "format": "double", "nullable": true },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/pb": {
      "post": {
        "tags": ["Deposits"],
        "operationId": "pandabaseWebhook",
        "summary": "Pandabase payment webhook",
        "description": "Receives payment event webhooks from Pandabase. Verified via HMAC signature in the `x-pandabase-signature` header.",
        "parameters": [
          {
            "name": "x-pandabase-signature",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "HMAC signature for webhook verification"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Pandabase webhook payload (schema varies by event type)"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Webhook processed" },
          "401": {
            "description": "Invalid signature"
          }
        }
      }
    },
    "/api/admin/gems": {
      "get": {
        "tags": ["Admin"],
        "operationId": "adminGetGems",
        "summary": "Get gem stock (admin)",
        "description": "Returns the current gem balance available for sale.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Gem stock",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GemBalance" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "patch": {
        "tags": ["Admin"],
        "operationId": "adminUpdateGems",
        "summary": "Update gem stock",
        "description": "Sets the gem balance available for sale.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GemBalance" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gem stock updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GemBalance" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/stock": {
      "get": {
        "tags": ["Admin"],
        "operationId": "adminGetAllStock",
        "summary": "Get all stock items (admin)",
        "description": "Returns all stock items including inactive ones.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "All stock items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/StockItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Admin"],
        "operationId": "adminCreateStockItem",
        "summary": "Create stock item",
        "description": "Adds a new stock item to the shop.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StockItemCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Stock item created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StockItem" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/stock/{id}": {
      "get": {
        "tags": ["Admin"],
        "operationId": "adminGetStockItem",
        "summary": "Get single stock item (admin)",
        "description": "Returns a single stock item by ID.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/StockItemId" }
        ],
        "responses": {
          "200": {
            "description": "Stock item",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StockItem" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Admin"],
        "operationId": "adminUpdateStockItem",
        "summary": "Update stock item",
        "description": "Partially updates a stock item. Only provided fields are changed.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/StockItemId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StockItemUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stock item updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StockItem" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "operationId": "adminDeleteStockItem",
        "summary": "Delete stock item",
        "description": "Permanently deletes a stock item.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/StockItemId" }
        ],
        "responses": {
          "200": {
            "description": "Stock item deleted"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/admin/settings": {
      "get": {
        "tags": ["Admin"],
        "operationId": "adminGetSettings",
        "summary": "Get settings (admin)",
        "description": "Returns current site settings.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Settings",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Settings" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "patch": {
        "tags": ["Admin"],
        "operationId": "adminUpdateSettings",
        "summary": "Update settings",
        "description": "Updates site settings.",
        "security": [{ "sessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Settings" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Settings" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/orders/{id}/cancel": {
      "post": {
        "tags": ["Admin"],
        "operationId": "adminCancelOrder",
        "summary": "Cancel order and refund",
        "description": "Cancels an order and refunds the purchase amount to the user's wallet.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "responses": {
          "200": {
            "description": "Order cancelled and refunded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/admin/orders/{id}/complete": {
      "post": {
        "tags": ["Admin"],
        "operationId": "adminCompleteOrder",
        "summary": "Complete order",
        "description": "Manually marks an order as completed. Provide either `botTradeId` (if delivered via bot) or `reason` (if manually fulfilled).",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "botTradeId": { "type": "string", "description": "Bot trade ID if delivered via bot" },
                  "reason": { "type": "string", "description": "Reason if manually fulfilled" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/admin/orders/cancel-stale": {
      "post": {
        "tags": ["Admin"],
        "operationId": "adminCancelStaleOrders",
        "summary": "Cancel all stale orders",
        "description": "Cancels all orders that are still in pending or processing status and refunds them.",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Stale orders cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cancelledCount": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/users/{id}/balance": {
      "post": {
        "tags": ["Admin"],
        "operationId": "adminAdjustBalance",
        "summary": "Adjust user balance",
        "description": "Adds to, removes from, or sets a user's wallet balance.",
        "security": [{ "sessionCookie": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "User ID (Roblox user ID)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount", "action"],
                "properties": {
                  "amount": { "type": "number", "format": "double", "description": "Amount in USD" },
                  "action": {
                    "type": "string",
                    "enum": ["add", "remove", "set"],
                    "description": "Balance adjustment action"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Balance adjusted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "newBalance": { "type": "number", "format": "double" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/bot/orders": {
      "get": {
        "tags": ["Bot"],
        "operationId": "botGetOrders",
        "summary": "Get pending orders for bot",
        "description": "Returns orders that are ready for the delivery bot to process.",
        "security": [{ "botApiKey": [] }],
        "parameters": [
          {
            "name": "include_processing",
            "in": "query",
            "schema": { "type": "boolean", "default": false },
            "description": "Include orders already being processed"
          }
        ],
        "responses": {
          "200": {
            "description": "Pending orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Order" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/bot/orders/{id}/processing": {
      "post": {
        "tags": ["Bot"],
        "operationId": "botMarkProcessing",
        "summary": "Mark order as processing",
        "description": "Bot marks an order as currently being processed (trade in progress).",
        "security": [{ "botApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "responses": {
          "200": {
            "description": "Order marked processing",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/bot/orders/{id}/complete": {
      "post": {
        "tags": ["Bot"],
        "operationId": "botCompleteOrder",
        "summary": "Mark order as completed",
        "description": "Bot marks an order as successfully delivered.",
        "security": [{ "botApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "responses": {
          "200": {
            "description": "Order completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/bot/orders/{id}/fail": {
      "post": {
        "tags": ["Bot"],
        "operationId": "botFailOrder",
        "summary": "Mark order as failed",
        "description": "Bot marks an order as failed. The purchase amount is refunded to the user's wallet.",
        "security": [{ "botApiKey": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": { "type": "string", "description": "Reason for failure (optional)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order failed and refunded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "JWT session cookie obtained via Roblox OAuth. httpOnly, signed with SESSION_SECRET."
      },
      "botApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-bot-api-key",
        "description": "API key for the delivery bot."
      }
    },
    "parameters": {
      "OrderId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Order ID"
      },
      "StockItemId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Stock item ID"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Roblox user ID" },
          "name": { "type": "string", "description": "Roblox username" },
          "displayName": { "type": "string", "description": "Roblox display name" },
          "avatar": { "type": "string", "format": "uri", "description": "Roblox avatar thumbnail URL" }
        }
      },
      "StockItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["sniper", "knife", "crate"]
          },
          "description": { "type": "string", "nullable": true },
          "priceUsd": { "type": "number", "format": "double" },
          "stock": { "type": "integer" },
          "rarity": { "type": "string", "nullable": true },
          "fx": { "type": "string", "nullable": true, "description": "Visual effect name" },
          "fragtrak": { "type": "string", "nullable": true, "description": "Frag tracker name" },
          "imageUrl": { "type": "string", "format": "uri", "nullable": true },
          "active": { "type": "boolean" }
        }
      },
      "StockItemCreate": {
        "type": "object",
        "required": ["name", "type", "priceUsd", "stock"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["sniper", "knife", "crate"]
          },
          "description": { "type": "string" },
          "priceUsd": { "type": "number", "format": "double" },
          "stock": { "type": "integer", "minimum": 0 },
          "rarity": { "type": "string" },
          "fx": { "type": "string" },
          "fragtrak": { "type": "string" },
          "active": { "type": "boolean", "default": true }
        }
      },
      "StockItemUpdate": {
        "type": "object",
        "description": "Partial update — only provided fields are changed.",
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["sniper", "knife", "crate"]
          },
          "description": { "type": "string", "nullable": true },
          "priceUsd": { "type": "number", "format": "double" },
          "stock": { "type": "integer", "minimum": 0 },
          "rarity": { "type": "string", "nullable": true },
          "fx": { "type": "string", "nullable": true },
          "fragtrak": { "type": "string", "nullable": true },
          "imageUrl": { "type": "string", "format": "uri", "nullable": true },
          "active": { "type": "boolean" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string", "description": "Roblox user ID of buyer" },
          "itemId": { "type": "string", "nullable": true, "description": "Stock item ID (null for gem orders)" },
          "itemName": { "type": "string" },
          "quantity": { "type": "integer" },
          "totalUsd": { "type": "number", "format": "double" },
          "status": {
            "type": "string",
            "enum": ["pending", "ready", "processing", "completed", "failed", "cancelled"],
            "description": "Current order status"
          },
          "botTradeId": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Deposit": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "amount": { "type": "number", "format": "double", "description": "Deposit amount in USD" },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "failed"],
            "description": "Payment status"
          },
          "checkoutUrl": { "type": "string", "format": "uri", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "BillingInfo": {
        "type": "object",
        "required": ["email", "address", "city", "state", "zip"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "address": { "type": "string" },
          "address2": { "type": "string", "nullable": true },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string", "default": "US" }
        }
      },
      "GemBalance": {
        "type": "object",
        "properties": {
          "balanceInK": {
            "type": "number",
            "description": "Gem balance in thousands"
          }
        }
      },
      "Settings": {
        "type": "object",
        "properties": {
          "itemsComingSoon": {
            "type": "boolean",
            "description": "Whether to show 'coming soon' state for items"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request body or parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Not authenticated or invalid session",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Insufficient permissions (not admin / not owner)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}