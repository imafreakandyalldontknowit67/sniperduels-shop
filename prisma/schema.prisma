generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────
model User {
  id              String   @id // Roblox user ID
  name            String
  displayName     String
  avatar          String?
  robloxCreatedAt String?

  // Discord linked account
  discordId         String?  @unique
  discordUsername   String?
  discordAvatar    String?
  discordLinkedAt  String?

  // Wallet
  walletBalance Decimal @default(0) @db.Decimal(12, 2)

  // Loyalty
  lifetimeSpend             Decimal @default(0) @db.Decimal(12, 2)
  discordFirstPurchaseUsed  Boolean @default(false)

  // Referral
  referralCode       String?  @unique
  referredBy         String?
  referralCreditedAt String?

  // Timestamps & status
  createdAt String
  lastLogin String
  isAdmin   Boolean @default(false)
  isVendor  Boolean @default(false)

  // Outage recovery DM opt-in (set when user clicks "DM me when bot's back"
  // either via OAuth ?reason=outage_notify or via /api/users/me/notify-prefs).
  // Bot fires recovery DM on heartbeat transition offline→online, then clears flag.
  notifyOnBotRecovery   Boolean   @default(false)
  lastRecoveryDmSentAt  DateTime?

  // Relations
  orders            Order[]
  deposits          Deposit[]
  vendorListings    VendorGemListing[]
  vendorDeposits    VendorDeposit[]
  vendorEarnings    VendorEarning[]
  vendorPayouts     VendorPayout[]
  creatorProfile    CreatorProfile?
  pendingBuyIntents PendingBuyIntent[]
}

// ─── Orders ──────────────────────────────────────────────────────────────────
enum OrderType {
  gems
  item
  crate
}

enum OrderStatus {
  pending
  processing
  completed
  failed
  refunded
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  userName    String
  type        OrderType
  itemName    String
  quantity    Int
  pricePerUnit Decimal    @db.Decimal(12, 2)
  totalPrice  Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(pending)
  playerReady Boolean     @default(false)
  skippedAt   String?
  createdAt   String
  updatedAt   String
  completedAt     String?
  reachedFrontAt  String?
  notes           String?
  vendorListingId String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// ─── Deposits ────────────────────────────────────────────────────────────────
enum DepositStatus {
  pending
  completed
  failed
  expired
}

model Deposit {
  id                    String        @id @default(cuid())
  userId                String
  amount                Decimal       @db.Decimal(12, 2)
  processingFee         Decimal?      @db.Decimal(12, 2)
  chargeAmount          Decimal?      @db.Decimal(12, 2)
  status                DepositStatus @default(pending)
  pandabaseInvoiceId    String        @unique
  pandabaseRefId        String?
  pandabaseCheckoutUrl  String
  paymentProviderId     String?       // NOWPayments payment_id for crypto deposits
  // Provenance for non-USD deposits — what the user typed in their currency
  // and the rate used to convert to the USD `amount` actually credited.
  // Nullable so legacy USD-only rows don't need a backfill.
  localAmount           Decimal?      @db.Decimal(12, 2)
  localCurrency         String?       @db.VarChar(3)
  fxRate                Decimal?      @db.Decimal(12, 6)
  createdAt             String
  updatedAt             String
  completedAt           String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─── Stock Items ─────────────────────────────────────────────────────────────
model StockItem {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(200)
  type        String  // 'sniper' | 'knife' | 'crate'
  description String? @db.VarChar(2000)
  priceUsd    Decimal @db.Decimal(12, 2)
  stock       Int     @default(0)
  imageUrl    String?
  rarity      String?
  fx          String?
  fragtrak    String?
  active      Boolean @default(true)
  createdAt   String
  updatedAt   String
}

// ─── Gem Stock (singleton) ───────────────────────────────────────────────────
model GemStock {
  id         String @id @default("singleton")
  balanceInK Int    @default(0)
  updatedAt  String
}

// ─── Site Settings (singleton) ──────────────────────────────────────────────
model SiteSettings {
  id               String  @id @default("singleton")
  itemsComingSoon  Boolean @default(true)
  depositsDisabled Boolean @default(false)
  updatedAt        String
}

// ─── Honeypot Blacklist ──────────────────────────────────────────────────────
model Blacklist {
  id        String   @id @default(cuid())
  ip        String?
  userId    String?
  reason    String
  endpoint  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([userId])
}

// ─── Vendor Gem Listings ────────────────────────────────────────────────────
model VendorGemListing {
  id         String  @id @default(cuid())
  vendorId   String
  pricePerK  Decimal @db.Decimal(12, 2)
  minOrderK  Int     @default(1)
  maxOrderK  Int     @default(500)
  stockK     Int     @default(0)
  bulkTiers       String?  // JSON: [{ minK, pricePerK }]
  platformFeeRate Decimal? @db.Decimal(5, 4) // null = default 3%
  active          Boolean  @default(true)
  createdAt  String
  updatedAt  String

  vendor User @relation(fields: [vendorId], references: [id])

  @@unique([vendorId])
  @@index([active])
}

// ─── Vendor Deposits (gems deposited to stock bot) ─────────────────────────
enum VendorDepositStatus {
  pending
  queued
  completed
  failed
}

model VendorDeposit {
  id        String              @id @default(cuid())
  vendorId  String
  amountK   Int
  status    VendorDepositStatus @default(pending)
  createdAt String
  updatedAt String

  vendor User @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
}

// ─── Vendor Earnings ───────────────────────────────────────────────────────
model VendorEarning {
  id          String  @id @default(cuid())
  vendorId    String
  orderId     String
  saleAmount  Decimal @db.Decimal(12, 2)
  platformFee Decimal @db.Decimal(12, 2)
  netAmount   Decimal @db.Decimal(12, 2)
  createdAt   String

  vendor User @relation(fields: [vendorId], references: [id])

  @@unique([orderId])
  @@index([vendorId])
}

// ─── Vendor Payouts (cash-out requests) ────────────────────────────────────
enum VendorPayoutStatus {
  pending
  completed
  rejected
}

model VendorPayout {
  id             String             @id @default(cuid())
  vendorId       String
  amount         Decimal            @db.Decimal(12, 2)
  paymentMethod  String
  status         VendorPayoutStatus @default(pending)
  adminNotes     String?
  createdAt      String
  updatedAt      String
  completedAt    String?

  vendor User @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
}

// ─── Transaction Ledger (audit log) ────────────────────────────────────────
enum TransactionType {
  deposit
  purchase
  vendor_earning
  vendor_payout
  refund
  referral_commission
  admin_adjust
}

model TransactionLedger {
  id          String          @id @default(cuid())
  type        TransactionType
  userId      String
  amount      Decimal         @db.Decimal(12, 2)
  description String
  relatedId   String?
  createdAt   String

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Bot State (key-value, survives deploys) ────────────────────────────────
model BotState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Session Blacklist ───────────────────────────────────────────────────────
model SessionBlacklist {
  jti       String @id // JWT ID
  expiresAt Int    // Unix timestamp (seconds)

  @@index([expiresAt])
}

// ─── Error Log (cross-app structured error capture) ───────────────────────
// Written from both the website and the Discord bot. Queried by a scheduled
// review agent to triage failures in critical user flows (auth link, order
// purchase, deposit webhooks).
model ErrorLog {
  id        String   @id @default(cuid())
  source    String   // 'site' | 'bot'
  where     String   // handler/function name, e.g. 'discord_callback', 'createDiscordUser'
  userId    String?  // null when not authenticated yet
  message   String   @db.VarChar(2000)
  context   String?  @db.VarChar(4000) // JSON-encoded extra fields
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source, where])
}

// ─── OAuth State (DB-backed, fallback for cookie loss) ──────────────────────
model OAuthState {
  state        String   @id
  codeVerifier String
  provider     String   // 'roblox' | 'discord'
  consumed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  // Carry intent through OAuth round-trip:
  //   reason='outage_notify' → set User.notifyOnBotRecovery on Discord callback
  //   intentId → resume buy flow on Roblox callback (PendingBuyIntent)
  reason       String?
  intentId     String?

  @@index([createdAt])
}

// ─── Pending Buy Intent (resume gem purchase across OAuth) ──────────────────
// Created when a logged-out user clicks Buy on /gems. Carried through Roblox
// OAuth via OAuthState.intentId. Read on /gems?resumeBuy={id} to hydrate the
// confirm modal. Optionally consumed by the deposits webhook to auto-execute
// after a top-up. userId is nullable until OAuth completes; consumer endpoints
// MUST verify userId matches the authenticated session.
model PendingBuyIntent {
  id          String    @id @default(cuid())
  userId      String?
  listingId   String
  amountK     Int
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

// ─── Referrals ──────────────────────────────────────────────────────────────
enum ReferralStatus {
  pending
  credited
  expired
}

model Referral {
  id               String         @id @default(cuid())
  referrerUserId   String
  referredUserId   String         @unique
  orderId          String?        @unique
  commissionAmount Decimal?       @db.Decimal(12, 2)
  status           ReferralStatus @default(pending)
  discordJoinedAt  String?
  createdAt        String
  creditedAt       String?

  @@index([referrerUserId])
}

// ─── Creator/Referral Program ───────────────────────────────────────────────
model CreatorProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  referralCode      String  @unique
  discordInviteCode String?
  tier              Int     @default(0)
  gemsAwarded       Int     @default(0)
  gemsClaimed       Int     @default(0)
  exchangeFee       Decimal @default(5.0) @db.Decimal(5, 2)
  createdAt         String
  updatedAt         String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([referralCode])
}
