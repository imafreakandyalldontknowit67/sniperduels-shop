generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────
model User {
  id              String   @id // Roblox user ID
  name            String
  displayName     String
  avatar          String?
  robloxCreatedAt String?

  // Discord linked account
  discordId         String?  @unique
  discordUsername   String?
  discordAvatar    String?
  discordLinkedAt  String?

  // Wallet
  walletBalance Decimal @default(0) @db.Decimal(12, 2)

  // Loyalty
  lifetimeSpend             Decimal @default(0) @db.Decimal(12, 2)
  discordFirstPurchaseUsed  Boolean @default(false)

  // Referral
  referralCode       String?  @unique
  referredBy         String?
  referralCreditedAt String?

  // Timestamps & status
  createdAt String
  lastLogin String
  isAdmin   Boolean @default(false)
  isVendor  Boolean @default(false)

  // Outage recovery DM opt-in (set when user clicks "DM me when bot's back"
  // either via OAuth ?reason=outage_notify or via /api/users/me/notify-prefs).
  // Bot fires recovery DM on heartbeat transition offline→online, then clears flag.
  notifyOnBotRecovery   Boolean   @default(false)
  lastRecoveryDmSentAt  DateTime?

  // Relations
  orders            Order[]
  deposits          Deposit[]
  vendorListings    VendorGemListing[]
  vendorDeposits    VendorDeposit[]
  vendorEarnings    VendorEarning[]
  vendorPayouts     VendorPayout[]
  creatorProfile    CreatorProfile?
  pendingBuyIntents PendingBuyIntent[]

  // Item marketplace
  vaultItems          VaultItem[]
  itemDepositSessions ItemDepositSession[]
  itemDeliveryJobs    ItemDeliveryJob[]
  itemWithdrawalJobs  ItemWithdrawalJob[]
}

// ─── Orders ──────────────────────────────────────────────────────────────────
enum OrderType {
  gems
  item
  crate
}

enum OrderStatus {
  pending
  processing
  completed
  failed
  refunded
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  userName    String
  type        OrderType
  itemName    String
  quantity    Int
  pricePerUnit Decimal    @db.Decimal(12, 2)
  totalPrice  Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(pending)
  playerReady Boolean     @default(false)
  skippedAt   String?
  createdAt   String
  updatedAt   String
  completedAt     String?
  reachedFrontAt  String?
  notes           String?
  vendorListingId String?
  vaultListingId  String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([vaultListingId])
}

// ─── Deposits ────────────────────────────────────────────────────────────────
enum DepositStatus {
  pending
  completed
  failed
  expired
}

model Deposit {
  id                    String        @id @default(cuid())
  userId                String
  amount                Decimal       @db.Decimal(12, 2)
  processingFee         Decimal?      @db.Decimal(12, 2)
  chargeAmount          Decimal?      @db.Decimal(12, 2)
  status                DepositStatus @default(pending)
  pandabaseInvoiceId    String        @unique
  pandabaseRefId        String?
  pandabaseCheckoutUrl  String
  paymentProviderId     String?       // NOWPayments payment_id for crypto deposits
  // Provenance for non-USD deposits — what the user typed in their currency
  // and the rate used to convert to the USD `amount` actually credited.
  // Nullable so legacy USD-only rows don't need a backfill.
  localAmount           Decimal?      @db.Decimal(12, 2)
  localCurrency         String?       @db.VarChar(3)
  fxRate                Decimal?      @db.Decimal(12, 6)
  createdAt             String
  updatedAt             String
  completedAt           String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─── Stock Items ─────────────────────────────────────────────────────────────
model StockItem {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(200)
  type        String  // 'sniper' | 'knife' | 'crate'
  description String? @db.VarChar(2000)
  priceUsd    Decimal @db.Decimal(12, 2)
  stock       Int     @default(0)
  imageUrl    String?
  rarity      String?
  fx          String?
  fragtrak    String?
  active      Boolean @default(true)
  createdAt   String
  updatedAt   String
}

// ─── Gem Stock (singleton) ───────────────────────────────────────────────────
model GemStock {
  id         String @id @default("singleton")
  balanceInK Int    @default(0)
  updatedAt  String
}

// ─── Site Settings (singleton) ──────────────────────────────────────────────
model SiteSettings {
  id               String  @id @default("singleton")
  itemsComingSoon  Boolean @default(true)
  depositsDisabled Boolean @default(false)
  updatedAt        String
}

// ─── Honeypot Blacklist ──────────────────────────────────────────────────────
model Blacklist {
  id        String   @id @default(cuid())
  ip        String?
  userId    String?
  reason    String
  endpoint  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([userId])
}

// ─── Vendor Gem Listings ────────────────────────────────────────────────────
model VendorGemListing {
  id         String  @id @default(cuid())
  vendorId   String
  pricePerK  Decimal @db.Decimal(12, 2)
  minOrderK  Int     @default(1)
  maxOrderK  Int     @default(500)
  stockK     Int     @default(0)
  bulkTiers       String?  // JSON: [{ minK, pricePerK }]
  // Fees. platformFeeRate = MANUAL admin override (null = use auto volume tier).
  // autoFeeRate = the rate the volume-tier recompute sets (null = not yet
  // evaluated -> falls back to the 3% default). Effective rate resolution
  // lives in lib/vendor-fees.ts: manual ?? auto ?? 0.03.
  platformFeeRate Decimal? @db.Decimal(5, 4) // manual override; null = auto-tier
  autoFeeRate     Decimal? @db.Decimal(5, 4) // volume-tier rate; null = unevaluated
  // Hysteresis for the 1-week grace before a discounted vendor reverts to 3%.
  // Set the first day weekly volume drops below the 650k threshold while still
  // discounted; cleared when they re-qualify. null = qualified / not discounted.
  feeTierBelowSince  DateTime?
  feeTierEvaluatedAt DateTime?      // last recompute time
  rolling7dVolumeK   Int @default(0) // cached weekly gem volume (k) for display
  active          Boolean  @default(true)
  createdAt  String
  updatedAt  String

  vendor User @relation(fields: [vendorId], references: [id])

  @@unique([vendorId])
  @@index([active])
}

// ─── Vendor Deposits (gems deposited to stock bot) ─────────────────────────
enum VendorDepositStatus {
  pending
  queued
  completed
  failed
}

model VendorDeposit {
  id        String              @id @default(cuid())
  vendorId  String
  amountK   Int
  status    VendorDepositStatus @default(pending)
  createdAt String
  updatedAt String

  vendor User @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
}

// ─── Vendor Earnings ───────────────────────────────────────────────────────
model VendorEarning {
  id          String  @id @default(cuid())
  vendorId    String
  orderId     String
  saleAmount  Decimal @db.Decimal(12, 2)
  platformFee Decimal @db.Decimal(12, 2)
  netAmount   Decimal @db.Decimal(12, 2)
  createdAt   String

  vendor User @relation(fields: [vendorId], references: [id])

  @@unique([orderId])
  @@index([vendorId])
}

// ─── Vendor Payouts (cash-out requests) ────────────────────────────────────
enum VendorPayoutStatus {
  pending
  completed
  rejected
}

model VendorPayout {
  id             String             @id @default(cuid())
  vendorId       String
  amount         Decimal            @db.Decimal(12, 2)
  paymentMethod  String
  status         VendorPayoutStatus @default(pending)
  adminNotes     String?
  createdAt      String
  updatedAt      String
  completedAt    String?

  vendor User @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
}

// ─── Transaction Ledger (audit log) ────────────────────────────────────────
enum TransactionType {
  deposit
  purchase
  vendor_earning
  vendor_payout
  refund
  referral_commission
  admin_adjust
}

model TransactionLedger {
  id          String          @id @default(cuid())
  type        TransactionType
  userId      String
  amount      Decimal         @db.Decimal(12, 2)
  description String
  relatedId   String?
  createdAt   String

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Bot State (key-value, survives deploys) ────────────────────────────────
model BotState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Session Blacklist ───────────────────────────────────────────────────────
model SessionBlacklist {
  jti       String @id // JWT ID
  expiresAt Int    // Unix timestamp (seconds)

  @@index([expiresAt])
}

// ─── Error Log (cross-app structured error capture) ───────────────────────
// Written from both the website and the Discord bot. Queried by a scheduled
// review agent to triage failures in critical user flows (auth link, order
// purchase, deposit webhooks).
model ErrorLog {
  id        String   @id @default(cuid())
  source    String   // 'site' | 'bot'
  where     String   // handler/function name, e.g. 'discord_callback', 'createDiscordUser'
  userId    String?  // null when not authenticated yet
  message   String   @db.VarChar(2000)
  context   String?  @db.VarChar(4000) // JSON-encoded extra fields
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source, where])
}

// ─── OAuth State (DB-backed, fallback for cookie loss) ──────────────────────
model OAuthState {
  state        String   @id
  codeVerifier String
  provider     String   // 'roblox' | 'discord'
  consumed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  // Carry intent through OAuth round-trip:
  //   reason='outage_notify' → set User.notifyOnBotRecovery on Discord callback
  //   intentId → resume buy flow on Roblox callback (PendingBuyIntent)
  reason       String?
  intentId     String?

  @@index([createdAt])
}

// ─── Pending Buy Intent (resume gem purchase across OAuth) ──────────────────
// Created when a logged-out user clicks Buy on /gems. Carried through Roblox
// OAuth via OAuthState.intentId. Read on /gems?resumeBuy={id} to hydrate the
// confirm modal. Optionally consumed by the deposits webhook to auto-execute
// after a top-up. userId is nullable until OAuth completes; consumer endpoints
// MUST verify userId matches the authenticated session.
model PendingBuyIntent {
  id          String    @id @default(cuid())
  userId      String?
  listingId   String
  amountK     Int
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

// ─── Referrals ──────────────────────────────────────────────────────────────
enum ReferralStatus {
  pending
  credited
  expired
}

model Referral {
  id               String         @id @default(cuid())
  referrerUserId   String
  referredUserId   String         @unique
  orderId          String?        @unique
  commissionAmount Decimal?       @db.Decimal(12, 2)
  status           ReferralStatus @default(pending)
  discordJoinedAt  String?
  createdAt        String
  creditedAt       String?

  @@index([referrerUserId])
}

// ─── Creator/Referral Program ───────────────────────────────────────────────
model CreatorProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  referralCode      String  @unique
  discordInviteCode String?
  tier              Int     @default(0)
  gemsAwarded       Int     @default(0)
  gemsClaimed       Int     @default(0)
  exchangeFee       Decimal @default(5.0) @db.Decimal(5, 2)
  createdAt         String
  updatedAt         String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([referralCode])
}

// ─── Outage Events ─────────────────────────────────────────────────────────
model OutageEvent {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  reason          String    // e.g. 'stale_heartbeat', 'stale_poll', 'no_signals'
  durationSeconds Int?      // computed on close: (endedAt - startedAt) in seconds

  @@index([startedAt])
}

// ─── Item Marketplace ──────────────────────────────────────────────────────
// Models mirror the raw-SQL migrations prisma/migrations/20260531*. They were
// never added to this schema, so the generated client lacked these accessors
// and every bot/v1 + marketplace DB route 500'd. Added 2026-06-04.

enum ItemCatalogSource {
  manual
  sniperduelsvalues
  bot_observed
  sweep
}

enum ItemCatalogType {
  sniper
  knife
}

enum CatalogCandidateStatus {
  pending
  approved
  rejected
  duplicate
}

enum VaultItemStatus {
  deposited
  listed
  reserved
  sold
  withdrawing
  withdrawn
}

enum ItemDepositSessionStatus {
  pending
  bot_in_trade
  awaiting_confirm
  completed
  cancelled
  expired
}

enum ItemDepositMode {
  auto_detect
  declared
}

enum ItemDeliveryStatus {
  queued
  bot_in_trade
  completed
  failed
}

enum ItemWithdrawalStatus {
  queued
  bot_in_trade
  completed
  failed
}

model ItemCatalog {
  id          String            @id @default(cuid())
  name        String            @unique
  weapon      String
  skin        String
  type        ItemCatalogType
  crate       String?
  slug        String?
  source      ItemCatalogSource @default(manual)
  active      Boolean           @default(true)
  firstSeenAt DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vaultItems VaultItem[]
  candidates CatalogCandidate[]

  @@index([weapon])
  @@index([type, active])
}

model CatalogCandidate {
  id            String                 @id @default(cuid())
  ocrName       String                 @unique
  weapon        String?
  skin          String?
  rarity        String?
  condition     String?
  fragtrakr     Boolean                @default(false)
  fx            String?
  crate         String?
  observedCount Int                    @default(1)
  firstSeenAt   DateTime               @default(now())
  lastSeenAt    DateTime               @default(now())
  screenshotUrl String?
  status        CatalogCandidateStatus @default(pending)
  approvedAsId  String?
  notes         String?

  approvedAs ItemCatalog? @relation(fields: [approvedAsId], references: [id], onDelete: SetNull)

  @@index([status, lastSeenAt])
  @@index([weapon, skin])
}

model VaultItem {
  id            String          @id @default(cuid())
  ownerId       String
  catalogId     String
  fingerprint   Json
  status        VaultItemStatus @default(deposited)
  depositedAt   DateTime        @default(now())
  listedAt      DateTime?
  soldAt        DateTime?
  withdrawnAt   DateTime?
  lastCellHint  Json?
  updatedAt     DateTime        @updatedAt

  owner      User               @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  catalog    ItemCatalog        @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  listing    VendorItemListing?
  delivery   ItemDeliveryJob?
  withdrawal ItemWithdrawalJob?

  @@index([ownerId, status])
  @@index([status, depositedAt])
  @@index([catalogId, status])
}

model VendorItemListing {
  id          String   @id @default(cuid())
  vaultItemId String   @unique
  priceUsd    Decimal  @db.Decimal(12, 2)
  minOfferUsd Decimal? @db.Decimal(12, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vaultItem VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)

  @@index([active, priceUsd])
  @@index([active, createdAt])
}

model ItemDepositSession {
  id            String                   @id @default(cuid())
  userId        String
  mode          ItemDepositMode          @default(auto_detect)
  status        ItemDepositSessionStatus @default(pending)
  declaredItems Json?
  detectedItems Json?
  createdAt     DateTime                 @default(now())
  expiresAt     DateTime
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, expiresAt])
}

model ItemDeliveryJob {
  id                  String             @id @default(cuid())
  vaultItemId         String             @unique
  orderId             String             @unique
  buyerUserId         String
  buyerRobloxName     String
  status              ItemDeliveryStatus @default(queued)
  attempts            Int                @default(0)
  lastError           String?
  createdAt           DateTime           @default(now())
  startedAt           DateTime?
  completedAt         DateTime?
  expectedFingerprint Json

  vaultItem VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Restrict)
  buyer     User      @relation(fields: [buyerUserId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([buyerUserId])
}

model ItemWithdrawalJob {
  id             String               @id @default(cuid())
  vaultItemId    String               @unique
  userId         String
  userRobloxName String
  status         ItemWithdrawalStatus @default(queued)
  attempts       Int                  @default(0)
  lastError      String?
  createdAt      DateTime             @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  vaultItem VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Restrict)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([userId])
}

model ItemStateLog {
  id          String   @id @default(cuid())
  vaultItemId String
  fromStatus  String?
  toStatus    String
  reason      String?
  triggeredBy String?
  createdAt   DateTime @default(now())

  @@index([vaultItemId, createdAt])
  @@index([createdAt])
}
